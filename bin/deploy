#!/usr/bin/env bash

usage() {
  echo "usage: $(basename $0) [-h|--help] [--jar] [--deploy] [--core] [--themes]"
  echo
  echo '  OPTIONS:'
  echo
  echo '  -h|--help show this help text'
}

POSITIONAL=()
while [[ $# -gt 0 ]]
do
key="$1"

case $key in
    -h|--help)
    # show usage and bail
    usage
    exit
    ;;
    --jar)
    SKIP_DEPLOY=1
    shift # past argument
    ;;
    --deploy)
    SKIP_JARS=1
    shift # past argument
    ;;
    --core)
    SKIP_THEMES=1
    shift # past argument
    ;;
    --themes)
    SKIP_CORE=1
    shift # past argument
    ;;
    *)
    POSITIONAL+=("$1") # save it in an array for later
    shift # past argument
    ;;
esac

done
set -- "${POSITIONAL[@]}" # restore positional parameters


main() {
  clojure -T:build clean

  if [[ -z $SKIP_CORE ]] ; then
    echo packaging core libs...

    # Build core jars
    if [[ -z $SKIP_CORE ]] ; then
      clojure -T:build jar :lib :auth
      clojure -T:build jar :lib :core
      clojure -T:build jar :lib :datahike
      clojure -T:build jar :lib :email
      clojure -T:build jar :lib :reitit
      clojure -T:build jar :lib :rum
      clojure -T:build jar :lib :theme
    fi

    # Deploy core jars
    if [[ -z $SKIP_DEPLOY ]] ; then
      clojure -T:build deploy :lib :auth
      clojure -T:build deploy :lib :core
      clojure -T:build deploy :lib :datahike
      clojure -T:build deploy :lib :email
      clojure -T:build deploy :lib :reitit
      clojure -T:build deploy :lib :rum
      clojure -T:build deploy :lib :theme
    fi
  fi

  if [[ $SKIP_THEMES ]] ; then
    exit 0
  fi

  echo packaging themes...

  # THEMES
  # These rely on bread-plugins-theme, and so deploy in a second round.
  if [[ -z $SKIP_JARS ]] ; then
    clojure -T:build jar :lib :theme-rise
  fi
  if [[ -z $SKIP_DEPLOY ]] ; then
    clojure -T:build deploy :lib :theme-rise
  fi
}


main
